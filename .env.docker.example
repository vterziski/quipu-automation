# Copy to .env.docker before running docker compose up
#
# Generate APP_KEY with:
#   docker compose run --rm app php artisan key:generate --show
# Paste the result (base64:...) as APP_KEY below.

# ── Firefly III ───────────────────────────────────────────────────────────────
APP_KEY=base64:CHANGE_ME_run_artisan_key_generate_shown_above=
APP_URL=http://localhost:8080
TRUSTED_PROXIES=**

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=secret_firefly_db_password

# ── MariaDB ───────────────────────────────────────────────────────────────────
MYSQL_DATABASE=firefly
MYSQL_USER=firefly
MYSQL_PASSWORD=secret_firefly_db_password
MYSQL_RANDOM_ROOT_PASSWORD=yes
